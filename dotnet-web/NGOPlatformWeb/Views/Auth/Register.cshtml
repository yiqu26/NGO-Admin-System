@model NGOPlatformWeb.Models.ViewModels.Auth.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>註冊 - NGO 平台</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Url.Content("~/css/auth/login.css")" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/js/all.min.js"></script>
    <style>
        .loading-plane {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }
        .plane-icon {
            font-size: 64px;
            animation: plane-fly 1.8s ease-in-out infinite;
            filter: drop-shadow(0 0 12px rgba(255,255,255,0.4));
        }
        @@keyframes plane-fly {
            0%   { transform: translateX(-30px) translateY(8px) rotate(-5deg); opacity: 0.6; }
            50%  { transform: translateX(0px) translateY(-8px) rotate(5deg); opacity: 1; }
            100% { transform: translateX(30px) translateY(8px) rotate(-5deg); opacity: 0.6; }
        }
        .loading-dots {
            display: flex;
            gap: 8px;
        }
        .loading-dots span {
            width: 8px; height: 8px;
            background: rgba(255,255,255,0.7);
            border-radius: 50%;
            animation: dot-bounce 1.2s ease-in-out infinite;
        }
        .loading-dots span:nth-child(2) { animation-delay: 0.2s; }
        .loading-dots span:nth-child(3) { animation-delay: 0.4s; }
        @@keyframes dot-bounce {
            0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
            40% { transform: scale(1.2); opacity: 1; }
        }
    </style>
    <script>
        // 在頁面載入前檢查是否需要顯示動畫
        const shouldShow = sessionStorage.getItem('showPlaneAnimation');
        console.log('註冊頁面檢查動畫標記:', shouldShow);
        
        if (shouldShow === 'true') {
            document.documentElement.style.setProperty('--initial-loading-display', 'flex');
            document.documentElement.style.setProperty('--initial-content-opacity', '0');
            console.log('註冊頁面設定為顯示動畫模式');
        } else {
            document.documentElement.style.setProperty('--initial-loading-display', 'none');
            document.documentElement.style.setProperty('--initial-content-opacity', '1');
            console.log('註冊頁面設定為正常顯示模式');
        }
    </script>
</head>
<body class="login-page">
    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="loading-overlay">
        <div class="loading-container">
            <div class="loading-plane">
                <div class="plane-icon">✈️</div>
                <div class="loading-dots">
                    <span></span><span></span><span></span>
                </div>
            </div>
        </div>
    </div>

    <!-- 全屏垂直水平置中 -->
    <div class="login-wrapper" id="mainContent">
        <div class="card login-container">
            <div class="row g-0">
                <!-- 左图 -->
                <div class="col-md-7 login-image"></div>

                <!-- 右表单 -->
                <div class="col-12 col-md-5 login-form-area">
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb p-0 bg-transparent mb-0">
                            <li class="breadcrumb-item">
                                <a href="@Url.Action("Index", "Home")" class="text-decoration-none d-inline-flex align-items-center">
                                    <i class="fas fa-home me-1"></i>首頁
                                </a>
                            </li>
                            <li class="breadcrumb-item">
                                <a href="@Url.Action("Login", "Auth")" class="text-decoration-none d-inline-flex align-items-center">
                                    <i class="fas fa-sign-in-alt me-1"></i>登入
                                </a>
                            </li>
                            <li class="breadcrumb-item active text-secondary" aria-current="page">
                                <i class="fas fa-user-plus me-1"></i>註冊
                            </li>
                        </ol>
                    </nav>
                    <div class="d-flex align-items-center mb-4">
                        <img src="~/images/logo.png" width="48" alt="Logo" />
                        <h2 class="h5 mb-0 fw-bold ms-2">加入恩舉！</h2>
                    </div>

                    <form asp-action="Register" method="post" class="register-form">
                        <!-- 只顯示模型級別的錯誤，不顯示個別欄位錯誤 -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none mb-3" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>註冊失敗</strong><br>
                            請檢查以下問題並重新提交：
                        </div>

                        <!-- 姓名 + 電子信箱 -->
                        <div class="form-row">
                            <div class="mb-3 flex-fill">
                                <label asp-for="Name" class="form-label">姓名：</label>
                                <input asp-for="Name" class="form-control form-control-lg rounded-3" placeholder="請輸入您的姓名" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            <div class="mb-3 flex-fill">
                                <label asp-for="Email" class="form-label">電子信箱：</label>
                                <input asp-for="Email" class="form-control form-control-lg rounded-3" placeholder="請輸入電子信箱" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- 電話號碼 + 身份證字號 -->
                        <div class="form-row">
                            <div class="mb-3 flex-fill">
                                <label asp-for="Phone" class="form-label">電話號碼：</label>
                                <input asp-for="Phone" class="form-control form-control-lg rounded-3" placeholder="請輸入電話號碼" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                            <div class="mb-3 flex-fill">
                                <label asp-for="IdentityNumber" class="form-label">身份證字號：</label>
                                <input asp-for="IdentityNumber" class="form-control form-control-lg rounded-3" placeholder="請輸入身份證字號" maxlength="10" />
                                <span asp-validation-for="IdentityNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- 密碼 -->
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">密碼：</label>
                            <div class="input-group input-group-lg password-input-group">
                                <input asp-for="Password" class="form-control rounded-2" placeholder="請輸入密碼 (至少6個字元)" />
                                <button class="btn" type="button" onclick="togglePassword(this)">
                                    <i class="fas fa-eye-slash"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <!-- 確認密碼 -->
                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">確認密碼：</label>
                            <div class="input-group input-group-lg password-input-group">
                                <input asp-for="ConfirmPassword" class="form-control rounded-2" placeholder="請再次輸入密碼" />
                                <button class="btn" type="button" onclick="togglePassword(this)">
                                    <i class="fas fa-eye-slash"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <!-- 註冊按鈕 -->
                        <button type="submit" class="btn btn-success btn-lg w-100 mb-3">
                            <i class="fas fa-user-plus me-2"></i>註冊帳號
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="@Url.Content("~/js/auth-transitions.js")"></script>
    <script>
        function togglePassword(button) {
            const input = button.previousElementSibling;
            const icon = button.querySelector("i");
            
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            }
        }

        // 驗證錯誤處理
        document.addEventListener('DOMContentLoaded', function() {
            // 檢查是否有個別欄位驗證錯誤
            const fieldErrors = document.querySelectorAll('.text-danger:not(:empty)');
            const alertSummary = document.querySelector('.alert-danger');
            
            if (fieldErrors.length > 0 && alertSummary) {
                // 如果有欄位錯誤，顯示摘要並添加動畫
                alertSummary.classList.remove('d-none');
                alertSummary.classList.add('show-errors');
            }
        });

        // Loading animation control
        document.addEventListener('DOMContentLoaded', function() {
            const loadingOverlay = document.getElementById('loadingOverlay');
            const mainContent = document.getElementById('mainContent');
            
            // 只有從首頁點擊按鈕才顯示動畫
            const shouldShowPlane = sessionStorage.getItem('showPlaneAnimation');
            
            if (shouldShowPlane === 'true') {
                // 1.5秒後隱藏動畫並顯示主內容
                setTimeout(function() {
                    console.log('註冊頁開始隱藏動畫並恢復頁面');
                    
                    // 隱藏loading overlay
                    loadingOverlay.classList.add('hide');
                    
                    // 完全移除loading overlay的顯示
                    setTimeout(() => {
                        loadingOverlay.style.display = 'none';
                    }, 500);
                    
                    // 重新設置CSS變數為正常顯示
                    document.documentElement.style.setProperty('--initial-content-opacity', '1');
                    
                    // 確保主內容完全可見和可點擊
                    mainContent.style.opacity = '1';
                    mainContent.style.pointerEvents = 'auto';
                    mainContent.style.zIndex = 'auto';
                    
                    // 確保body也是可點擊的
                    document.body.style.pointerEvents = 'auto';
                    
                    sessionStorage.removeItem('showPlaneAnimation');
                    console.log('註冊頁動畫結束，所有設置已恢復正常');
                }, 1500);
            }
            
            // 清除頁面跳轉標記
            sessionStorage.removeItem('skipLoadingAnimation');
        });
    </script>
</body>
</html>
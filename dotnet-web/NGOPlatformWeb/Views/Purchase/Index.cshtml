@{
    ViewData["Title"] = "物資認購";
}

@Html.AntiForgeryToken()

<link rel="stylesheet" href="~/css/purchase/purchase.css" asp-append-version="true" />

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger alert-dismissible fade show mx-auto mt-3" role="alert" style="max-width:1100px;">
        @ViewBag.Error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (ViewBag.EmergencyError != null)
{
    <div class="alert alert-warning alert-dismissible fade show mx-auto mt-3" role="alert" style="max-width:1100px;">
        @ViewBag.EmergencyError
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="purchase-page">

    <!-- Hero -->
    <section class="purchase-hero">
        <div class="purchase-hero-text-wrap">
            <div class="purchase-hero-text">
                <span class="purchase-eyebrow">物資認購</span>
                <h1 class="purchase-hero-title">每一份認購<br>都直接送達</h1>
                <p class="purchase-hero-desc">
                    您的捐助將由我們的社工精準配送給有需要的個案家庭。<br>
                    選擇套組或回應即時緊急需求，讓愛心化為實際行動。
                </p>
                <a href="#packages" class="purchase-hero-cta">查看援助套組</a>
            </div>
        </div>
        <div class="purchase-hero-image">
            <img src="/images/Caseshoppingback.png" asp-append-version="true" alt="物資認購">
        </div>
    </section>

    <!-- 緊急需求 -->
    @if (ViewBag.EmergencyNeeds != null && ((IEnumerable<dynamic>)ViewBag.EmergencyNeeds).Any())
    {
        <section class="purchase-section emergency-section">
            <div class="container">
                <div class="purchase-section-header">
                    <span class="purchase-section-eyebrow">即時需求</span>
                    <h2 class="purchase-section-title">個案緊急需求</h2>
                </div>

                <div class="emergency-grid">
                    @foreach (dynamic item in ViewBag.EmergencyNeeds)
                    {
                        <div class="emergency-card">
                            <div class="emergency-indicator @(item.Priority == "Urgent" ? "urgent" : item.Priority == "High" ? "high" : item.Priority == "Low" ? "low" : "normal")">
                                @(item.Priority == "Urgent" ? "極緊急" : item.Priority == "High" ? "高優先" : item.Priority == "Low" ? "低優先" : "普通")
                            </div>

                            <div class="card-img">
                                <img src="@item.ImageUrl" alt="@item.SupplyName"
                                     onerror="this.src='/images/activityback2.png'">
                                <div class="card-overlay">
                                    <div class="case-badge">個案 #@item.CaseId</div>
                                </div>
                            </div>

                            <div class="card-body">
                                <h4 class="card-title">@item.SupplyName</h4>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <p class="card-description">@item.Description</p>
                                }
                                <div class="progress-section">
                                    <div class="progress-info">
                                        <span>募集進度</span>
                                        <span>@(item.NeededQuantity - item.RemainingQuantity)/@item.NeededQuantity</span>
                                    </div>
                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width: @(item.NeededQuantity > 0 ? (item.NeededQuantity - item.RemainingQuantity) * 100 / item.NeededQuantity : 0)%"></div>
                                    </div>
                                    <div class="remaining">還需要 <strong>@item.RemainingQuantity 份</strong></div>
                                </div>
                                <button class="emergency-btn" onclick="directPurchase(null, 1, @item.Id, 'emergency')">
                                    <span>立即援助</span>
                                    <i class="fas fa-arrow-right" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Emergency Modal -->
                        <div class="modal fade" id="modal@(item.Id)" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="emergency-header">
                                        <h5>緊急援助確認</h5>
                                        <button type="button" class="purchase-modal-close" data-bs-dismiss="modal" aria-label="關閉">✕</button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="modal-item">
                                            <img src="@item.ImageUrl" alt="@item.SupplyName"
                                                 onerror="this.src='/images/activityback2.png'">
                                            <div>
                                                <h6>@item.SupplyName</h6>
                                                <p>個案 #@item.CaseId 的緊急需求</p>
                                            </div>
                                        </div>
                                        <div class="quantity-selector">
                                            <label>選擇援助數量</label>
                                            <select class="purchase-form-select">
                                                @for (int i = 1; i <= item.RemainingQuantity; i++)
                                                {
                                                    <option value="@i">@i 份</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="trust-note">
                                            您的援助將直接送達個案手中，全程透明追蹤
                                        </div>
                                    </div>
                                    <div class="modal-footer border-0 pt-0">
                                        <button type="button" class="purchase-btn secondary" data-bs-dismiss="modal">稍後決定</button>
                                        <button type="button" class="purchase-btn emergency">確認援助</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    <!-- 援助套組 -->
    <section id="packages" class="purchase-section packages-section">
        <div class="container">
            <div class="purchase-section-header">
                <span class="purchase-section-eyebrow">援助套組</span>
                <h2 class="purchase-section-title">選擇您要捐贈的物資組合</h2>
            </div>

            <div class="packages-grid">
                <!-- 醫療照護套組 -->
                <div class="package-card">
                    <span class="package-num">01</span>
                    <div class="package-header">
                        <h4>醫療照護套組</h4>
                        <div class="package-price" id="medical-price-display">NT$ 705</div>
                    </div>
                    <div class="package-body">
                        <div class="package-items">
                            <div class="package-item"><span>口罩 x 2盒</span></div>
                            <div class="package-item"><span>酒精 x 2瓶</span></div>
                            <div class="package-item"><span>體溫計 x 2支</span></div>
                            <div class="package-item"><span>紗布繃帶 x 5組</span></div>
                        </div>
                        <p class="package-desc">適合需要醫療照護的長者或慢性病患</p>
                        <div class="package-quantity">
                            <label>捐贈數量</label>
                            <select class="quantity-select" id="medical-quantity" onchange="updatePackagePrice('medical', 705)">
                                <option value="1">1組 — NT$ 705</option>
                                <option value="2">2組 — NT$ 1,410</option>
                                <option value="3">3組 — NT$ 2,115</option>
                            </select>
                        </div>
                        <button class="package-btn" onclick="buyPackageWithQuantity('medical')">
                            <span>立即捐贈</span>
                            <i class="fas fa-arrow-right" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>

                <!-- 營養食物套組（featured） -->
                <div class="package-card package-card--featured">
                    <span class="package-num">02</span>
                    <div class="package-header">
                        <h4>營養食物套組</h4>
                        <div class="package-price" id="food-price-display">NT$ 605</div>
                    </div>
                    <div class="package-body">
                        <div class="package-items">
                            <div class="package-item"><span>糙米 x 3包</span></div>
                            <div class="package-item"><span>玉米罐頭 x 4罐</span></div>
                            <div class="package-item"><span>蘋果麵包 x 6個</span></div>
                            <div class="package-item"><span>豆奶 x 12瓶</span></div>
                        </div>
                        <p class="package-desc">提供一周基本營養需求，幫助家庭度過困難</p>
                        <div class="package-quantity">
                            <label>捐贈數量</label>
                            <select class="quantity-select" id="food-quantity" onchange="updatePackagePrice('food', 605)">
                                <option value="1">1組 — NT$ 605</option>
                                <option value="2">2組 — NT$ 1,210</option>
                                <option value="3">3組 — NT$ 1,815</option>
                            </select>
                        </div>
                        <button class="package-btn" onclick="buyPackageWithQuantity('food')">
                            <span>立即捐贈</span>
                            <i class="fas fa-arrow-right" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>

                <!-- 清潔護理套組 -->
                <div class="package-card">
                    <span class="package-num">03</span>
                    <div class="package-header">
                        <h4>清潔護理套組</h4>
                        <div class="package-price" id="hygiene-price-display">NT$ 415</div>
                    </div>
                    <div class="package-body">
                        <div class="package-items">
                            <div class="package-item"><span>洗髮精 x 1瓶</span></div>
                            <div class="package-item"><span>沐浴乳 x 1瓶</span></div>
                            <div class="package-item"><span>肥皂 x 4塊</span></div>
                            <div class="package-item"><span>濕紙巾 x 5包</span></div>
                        </div>
                        <p class="package-desc">維持基本清潔衛生，提升生活品質</p>
                        <div class="package-quantity">
                            <label>捐贈數量</label>
                            <select class="quantity-select" id="hygiene-quantity" onchange="updatePackagePrice('hygiene', 415)">
                                <option value="1">1組 — NT$ 415</option>
                                <option value="2">2組 — NT$ 830</option>
                                <option value="3">3組 — NT$ 1,245</option>
                            </select>
                        </div>
                        <button class="package-btn" onclick="buyPackageWithQuantity('hygiene')">
                            <span>立即捐贈</span>
                            <i class="fas fa-arrow-right" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>

@section Scripts {
    <script>
        // 直接購買函數（緊急需求）
        function directPurchase(supplyId, quantity, emergencyNeedId, supplyType) {
            const clickedBtn = event.target.closest('button');
            if (clickedBtn) {
                const originalHTML = clickedBtn.innerHTML;
                clickedBtn.disabled = true;
                clickedBtn.innerHTML = '<span>處理中...</span>';
                setTimeout(() => {
                    clickedBtn.disabled = false;
                    clickedBtn.innerHTML = originalHTML;
                }, 10000);
            }

            const form = $('<form>', { method: 'POST', action: '@Url.Action("DirectPurchase", "Purchase")' });
            form.append($('<input>', { type: 'hidden', name: 'supplyId', value: supplyId }));
            form.append($('<input>', { type: 'hidden', name: 'quantity', value: quantity }));
            if (emergencyNeedId) {
                form.append($('<input>', { type: 'hidden', name: 'emergencyNeedId', value: emergencyNeedId }));
            }
            form.append($('<input>', { type: 'hidden', name: '__RequestVerificationToken', value: $('input[name="__RequestVerificationToken"]').val() }));
            $('body').append(form);
            form.submit();
        }

        // 更新套組價格顯示
        function updatePackagePrice(packageType, basePrice) {
            const quantity = parseInt(document.getElementById(packageType + '-quantity').value);
            const totalPrice = basePrice * quantity;
            const priceEl = document.getElementById(packageType + '-price-display');
            if (priceEl) {
                priceEl.textContent = 'NT$ ' + totalPrice.toLocaleString();
            }
        }

        // 帶數量的套組購買
        function buyPackageWithQuantity(packageType) {
            const clickedBtn = event.target.closest('button');
            if (clickedBtn) {
                const originalHTML = clickedBtn.innerHTML;
                clickedBtn.disabled = true;
                clickedBtn.innerHTML = '<span>處理中...</span>';
                setTimeout(() => {
                    clickedBtn.disabled = false;
                    clickedBtn.innerHTML = originalHTML;
                }, 10000);
            }

            const quantity = parseInt(document.getElementById(packageType + '-quantity').value) || 1;
            const form = $('<form>', { method: 'POST', action: '@Url.Action("BuyPackage", "Purchase")' });
            form.append($('<input>', { type: 'hidden', name: 'packageType', value: packageType }));
            form.append($('<input>', { type: 'hidden', name: 'quantity', value: quantity }));
            form.append($('<input>', { type: 'hidden', name: '__RequestVerificationToken', value: $('input[name="__RequestVerificationToken"]').val() }));
            $('body').append(form);
            form.submit();
        }
    </script>
}

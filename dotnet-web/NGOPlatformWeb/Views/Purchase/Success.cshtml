@model NGOPlatformWeb.Models.ViewModels.Purchase.OrderResultViewModel
@{
    var isSuccess = Model.PaymentStatus.Contains("成功") || Model.PaymentStatus == "已付款";
    ViewData["Title"] = isSuccess ? "捐贈成功" : "付款處理中";
}

<link rel="stylesheet" href="~/css/purchase/payment.css" asp-append-version="true" />

<div class="success-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <!-- 狀態動畫 -->
                <div class="success-animation">
                    @if (isSuccess)
                    {
                        <div class="success-circle">
                            <div class="success-check"></div>
                        </div>
                        <h1 class="success-title">感謝您的捐贈</h1>
                        <p class="success-subtitle">您的愛心物資將由社工配送到有需要的個案手中</p>
                    }
                    else
                    {
                        <div class="warning-circle">
                            <div class="warning-mark">!</div>
                        </div>
                        <h1 class="warning-title">付款未完成</h1>
                        <p class="warning-subtitle">付款過程中發生問題，您可以查看認購記錄並重新嘗試</p>
                    }
                </div>

                <!-- 訂單詳情 -->
                <div class="order-details">
                    <div class="details-header">
                        <h3>@(isSuccess ? "捐贈詳情" : "訂單詳情")</h3>
                        <div class="order-number">@Model.OrderNumber</div>
                    </div>
                    <div class="details-content">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="detail-item">
                                    <label>捐贈物資</label>
                                    <div class="detail-value">
                                        @Model.SupplyName
                                        @if (Model.IsEmergency)
                                        {
                                            <span class="emergency-badge ms-1">緊急需求</span>
                                        }
                                    </div>
                                </div>
                                <div class="detail-item">
                                    <label>捐贈數量</label>
                                    <div class="detail-value">
                                        @(Model.Quantity > 0 ? Model.Quantity : 1)
                                        @(Model.SupplyName.Contains("套組") || Model.SupplyName.Contains("組合包") ? "組" : "份")
                                    </div>
                                </div>
                                @if (Model.CaseId.HasValue)
                                {
                                    <div class="detail-item">
                                        <label>受助個案</label>
                                        <div class="detail-value">個案 #@Model.CaseId</div>
                                    </div>
                                }
                            </div>
                            <div class="col-md-6">
                                <div class="detail-item">
                                    <label>捐贈金額</label>
                                    <div class="detail-value amount">NT$ @Model.TotalPrice.ToString("N0")</div>
                                </div>
                                <div class="detail-item">
                                    <label>捐贈時間</label>
                                    <div class="detail-value">@Model.OrderDate.ToString("yyyy/MM/dd HH:mm")</div>
                                </div>
                                <div class="detail-item">
                                    <label>付款狀態</label>
                                    <div class="detail-value status @(isSuccess ? "success" : "failed")">
                                        @Model.PaymentStatus
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (isSuccess)
                {
                    <!-- 下一步 -->
                    <div class="next-actions">
                        <h4>接下來</h4>
                        <div class="action-cards">
                            <div class="action-card">
                                <div class="action-icon">
                                    <i class="fas fa-envelope" aria-hidden="true"></i>
                                </div>
                                <div class="action-content">
                                    <h5>收據已寄送</h5>
                                    <p>捐贈收據已發送至您的電子信箱</p>
                                </div>
                            </div>
                            <div class="action-card">
                                <div class="action-icon">
                                    <i class="fas fa-truck" aria-hidden="true"></i>
                                </div>
                                <div class="action-content">
                                    <h5>配送作業中</h5>
                                    <p>社工將盡快安排物資配送</p>
                                </div>
                            </div>
                            <div class="action-card">
                                <div class="action-icon">
                                    <i class="fas fa-history" aria-hidden="true"></i>
                                </div>
                                <div class="action-content">
                                    <h5>查看紀錄</h5>
                                    <p>在個人頁面查看所有認購紀錄</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 感謝訊息 -->
                    <div class="thank-you-section">
                        <div class="thank-you-content">
                            <h4>親愛的 @Model.DonorName，</h4>
                            <p>感謝您選擇成為愛心的傳遞者。您的捐助將確實送到有需要的個案手中。</p>
                            <div class="signature">
                                <strong>NGO 愛心平台團隊</strong><br>
                                <small>@DateTime.Now.ToString("yyyy年MM月dd日")</small>
                            </div>
                        </div>
                    </div>
                }

                <!-- 行動按鈕 -->
                <div class="action-buttons">
                    @if (isSuccess)
                    {
                        <a href="@Url.Action("Index", "Purchase")" class="btn btn-primary">繼續捐贈</a>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">返回首頁</a>
                        <button class="btn btn-outline-primary" onclick="window.print()">列印收據</button>
                    }
                    else
                    {
                        <a href="@Url.Action("PurchaseRecords", "User")" class="btn btn-warning">查看認購記錄</a>
                        <a href="@Url.Action("Index", "Purchase")" class="btn btn-primary">重新選擇物資</a>
                        <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">返回首頁</a>
                    }
                </div>

                @if (isSuccess)
                {
                    <div class="share-section">
                        <h5>分享愛心行動</h5>
                        <div class="share-buttons">
                            <a href="#" class="share-btn facebook" onclick="shareToFacebook()">
                                <i class="fab fa-facebook-f" aria-hidden="true"></i> Facebook
                            </a>
                            <a href="#" class="share-btn line" onclick="shareToLine()">
                                <i class="fab fa-line" aria-hidden="true"></i> LINE
                            </a>
                            <a href="#" class="share-btn copy" onclick="copyLink(); return false;">
                                <i class="fas fa-link" aria-hidden="true"></i> 複製連結
                            </a>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            setTimeout(() => $('.success-animation').addClass('animate'), 300);
            setTimeout(() => $('.order-details').addClass('fade-in'), 700);
            setTimeout(() => $('.next-actions').addClass('fade-in'), 1000);
            setTimeout(() => $('.thank-you-section').addClass('fade-in'), 1300);
        });

        function shareToFacebook() {
            window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(window.location.href), '_blank');
        }

        function shareToLine() {
            window.open('https://social-plugins.line.me/lineit/share?url=' + encodeURIComponent(window.location.href), '_blank');
        }

        function copyLink() {
            navigator.clipboard.writeText(window.location.href).then(() => alert('連結已複製'));
        }
    </script>
}

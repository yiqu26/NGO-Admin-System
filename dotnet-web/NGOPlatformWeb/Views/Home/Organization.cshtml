@{
    ViewBag.Title = "組織介紹";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/organization-page.css" asp-append-version="true" />
}

<!-- ① Hero：圖片從底部漸層到深色，標題左對齊壓在底部 -->
<div class="org-hero">
    <div class="org-hero-content">
        <p class="org-hero-eyebrow">About Us</p>
        <h1>關於恩舉</h1>
        <p class="org-hero-sub">每一份善意，都能在他人生命中留下光</p>
    </div>
</div>

<!-- ② 使命宣言：teal 漸層底，大引言置中 -->
<div class="org-mission">
    <div class="mission-inner">
        <span class="mission-quote-mark">"</span>
        <p class="mission-text">
            一個被關懷的孩子，能長出希望的翅膀。<br />
            每一份小小的善意，都能在他人的生命中留下光。
        </p>
        <span class="mission-author">恩舉基金會 創立宗旨</span>
    </div>
</div>

<!-- ③ 內容：左欄時間軸 + 右欄目標 -->
<div class="org-content">

    <!-- 左：年史時間軸 -->
    <div class="org-timeline">
        <p class="section-label">History</p>
        <h2 class="section-title">組織創立年史</h2>

        <ul class="timeline">
            <li class="timeline-item">
                <p class="timeline-year">2022 — 草創期</p>
                <p class="timeline-body">
                    一群有社工背景與公益熱忱的夥伴共同發起。
                    走訪偏鄉，發現許多孩童在經濟弱勢環境下成長，
                    缺乏基本物資與心靈支持。
                </p>
            </li>
            <li class="timeline-item">
                <p class="timeline-year">2022 — 行動啟動</p>
                <p class="timeline-body">
                    從最初幾戶家庭的協助開始，
                    逐步拓展服務規模，
                    結合社會各界力量。
                </p>
            </li>
            <li class="timeline-item">
                <p class="timeline-year">2023 — 平台建立</p>
                <p class="timeline-body">
                    於線上建立資源媒合平台，讓社工可以快速掌握孩童需求，
                    也讓社會大眾能即時響應、提供物資。
                </p>
            </li>
            <li class="timeline-item">
                <p class="timeline-year">持續進行中</p>
                <p class="timeline-body">
                    始終堅持：每一份小小的善意，
                    都能在他人的生命中留下光。
                </p>
            </li>
        </ul>
    </div>

    <!-- 右：目標 Bento Grid -->
    <div class="org-goals">
        <p class="section-label">Vision</p>
        <h2 class="section-title">目標與前景</h2>

        <ul class="goals-bento">

            <!-- 大卡（跨兩行） -->
            <li class="goal-card goal-card--featured">
                <span class="goal-deco" aria-hidden="true">01</span>
                <p class="goal-tag">Core Mission</p>
                <h3 class="goal-title">讓每個孩子<br />都能被看見、被支持</h3>
                <p class="goal-sub">擴大服務據點，觸及更多被社會忽略的角落。</p>
            </li>

            <!-- 右側小卡 1 -->
            <li class="goal-card">
                <span class="goal-deco" aria-hidden="true">02</span>
                <p class="goal-tag">Technology</p>
                <h3 class="goal-title">即時、透明的媒合</h3>
                <p class="goal-sub">強化數位平台，讓物資流向更清晰。</p>
            </li>

            <!-- 右側小卡 2 -->
            <li class="goal-card">
                <span class="goal-deco" aria-hidden="true">03</span>
                <p class="goal-tag">Partnership</p>
                <h3 class="goal-title">跨域合作網絡</h3>
                <p class="goal-sub">結合學校、醫療、企業，建立完整關懷體系。</p>
            </li>

            <!-- 橫幅卡（跨兩欄） -->
            <li class="goal-card goal-card--wide">
                <span class="goal-deco" aria-hidden="true">04</span>
                <div class="goal-main">
                    <p class="goal-tag">Long-term</p>
                    <h3 class="goal-title">身心並重的成長支持</h3>
                </div>
                <p class="goal-sub">
                    不只是物資援助，更提供教育資源與心理陪伴，
                    讓孩子在身心發展上健全成長。
                </p>
            </li>

        </ul>
    </div>

</div>

<!-- ④ CTA -->
<div class="org-cta">
    <div class="cta-inner">
        <p class="cta-sub">Join Us</p>
        <h2 class="cta-heading">想為孩子做些什麼？</h2>
        <p class="cta-desc">每一步行動都有意義，公益不是單打獨鬥，而是每一個人願意多走一步的累積。</p>
        <div class="cta-actions">
            <a href="/Activity/CaseActivityIndex" class="cta-btn-primary">參與活動</a>
            <a href="/Purchase/Index" class="cta-btn-secondary">認購物資</a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('visible');
                    observer.unobserve(e.target);
                }
            });
        }, { threshold: 0.15 });

        // 區塊進場
        document.querySelectorAll('.org-mission, .org-cta').forEach(el => observer.observe(el));

        // 時間軸：逐條錯開
        const timelineObs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    const items = e.target.querySelectorAll('.timeline-item');
                    items.forEach((item, i) => {
                        setTimeout(() => item.classList.add('visible'), i * 120);
                    });
                    timelineObs.unobserve(e.target);
                }
            });
        }, { threshold: 0.1 });

        const timeline = document.querySelector('.timeline');
        if (timeline) timelineObs.observe(timeline);

        // 目標卡片：逐張錯開進場
        const goalObs = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    const items = e.target.querySelectorAll('.goal-card');
                    items.forEach((item, i) => {
                        setTimeout(() => item.classList.add('visible'), i * 110);
                    });
                    goalObs.unobserve(e.target);
                }
            });
        }, { threshold: 0.08 });

        const goalsBento = document.querySelector('.goals-bento');
        if (goalsBento) goalObs.observe(goalsBento);
    </script>
}

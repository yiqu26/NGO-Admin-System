@model HomeViewModel
@{
    ViewData["Title"] = "首頁";
}

@section Styles {
    <link rel="stylesheet" href="~/css/components/carousel.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/activity-cards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/shared/homepage-new.css" asp-append-version="true" />
}

<!-- Hero 輪播 -->
<section class="hero-carousel">
    <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
        <div class="carousel-indicators">
            @for (int i = 0; i < Model.CarouselItems.Count; i++)
            {
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i"
                        class="@(i == 0 ? "active" : "")" aria-current="@(i == 0 ? "true" : "false")"
                        aria-label="Slide @(i + 1)"></button>
            }
        </div>
        <div class="carousel-inner">
            @for (int i = 0; i < Model.CarouselItems.Count; i++)
            {
                var item = Model.CarouselItems[i];
                <div class="carousel-item @(i == 0 ? "active" : "")">
                    <div class="carousel-slide">
                        <img src="@item.ImageUrl" asp-append-version="true" alt="@item.Title" class="carousel-bg">
                        <div class="carousel-overlay"></div>
                        <div class="carousel-content">
                            <div class="container">
                                <div class="col-lg-7 col-xl-6">
                                    <h1 class="carousel-title animate-up">@item.Title</h1>
                                    <p class="carousel-description animate-up delay-1">@item.Description</p>
                                    <div class="carousel-buttons animate-up delay-2">
                                        <a href="@item.ButtonLink" class="btn-hero-primary">@item.ButtonText</a>
                                        <a href="/Home/Organization" class="btn-hero-outline">了解更多</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>
</section>

<!-- 影響力數字 -->
<section class="impact-strip">
    <div class="impact-inner">
        <span class="impact-eyebrow">我們的影響力</span>
        <div class="impact-numbers">
            <div class="impact-stat">
                <span class="stat-num" data-count="@Model.ImpactStats.TotalCases">0</span>
                <div class="stat-info">
                    <span class="stat-label">受助個案</span>
                    <span class="stat-desc">提供生活援助與就業輔導</span>
                </div>
            </div>
            <span class="impact-sep" aria-hidden="true">—</span>
            <div class="impact-stat">
                <span class="stat-num" data-count="@Model.ImpactStats.TotalActivities">0</span>
                <div class="stat-info">
                    <span class="stat-label">舉辦活動</span>
                    <span class="stat-desc">技能培訓、心理支持</span>
                </div>
            </div>
            <span class="impact-sep" aria-hidden="true">—</span>
            <div class="impact-stat">
                <span class="stat-num" data-count="@Model.ImpactStats.TotalParticipants">0</span>
                <div class="stat-info">
                    <span class="stat-label">支持者</span>
                    <span class="stat-desc">加入我們的一般會員</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 使命 2 欄 -->
<section class="mission-section">
    <div class="mission-image-col">
        <img src="@Model.MissionStatement.ImageUrl" asp-append-version="true" alt="組織使命">
    </div>
    <div class="mission-text-col">
        <span class="section-eyebrow">關於我們</span>
        <h2 class="mission-heading">@Model.MissionStatement.Title</h2>
        <p class="mission-body">@Model.MissionStatement.Description</p>
        <a href="/Home/Organization" class="mission-link">深入了解 →</a>
    </div>
</section>

<!-- 三種參與方式 -->
<section class="paths-section">
    <div class="container">
        <span class="section-eyebrow" style="display:block; text-align:center;">如何參與</span>
        <div class="paths-grid">
            <article class="path-card">
                <span class="path-num">01</span>
                <h3 class="path-title">成為志工</h3>
                <p class="path-body">用時間與專業協助需要的人，報名參與各類社區服務活動。</p>
                <a href="/Activity/Index" class="path-link">查看活動</a>
            </article>
            <article class="path-card path-card--featured">
                <span class="path-num">02</span>
                <h3 class="path-title">認購物資</h3>
                <p class="path-body">認購生活必需品，直接送達有需要的家庭，讓愛化為實際行動。</p>
                <a href="/Purchase/Index" class="path-link">立即捐助</a>
            </article>
            <article class="path-card">
                <span class="path-num">03</span>
                <h3 class="path-title">尋求協助</h3>
                <p class="path-body">如果您或家人正面臨困難，我們提供多元支援服務，讓您不孤單。</p>
                <a href="/Auth/Register" class="path-link">了解服務</a>
            </article>
        </div>
    </div>
</section>

<!-- 即將舉行的活動 -->
<section class="activities-section">
    <div class="container">
        <span class="section-eyebrow" style="display:block; text-align:center;">即將舉行</span>
        <h2 class="activities-heading">近期活動</h2>

        @if (Model.RecentActivities.Any())
        {
            <div class="activity-carousel-container">
                <div id="activityCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
                    <div class="carousel-indicators">
                        @for (int i = 0; i < Model.RecentActivities.Count; i++)
                        {
                            <button type="button" data-bs-target="#activityCarousel" data-bs-slide-to="@i"
                                    class="@(i == 0 ? "active" : "")" aria-label="Activity @(i + 1)"></button>
                        }
                    </div>
                    <div class="carousel-inner">
                        @for (int i = 0; i < Model.RecentActivities.Count; i++)
                        {
                            var activity = Model.RecentActivities[i];
                            var imageUrl = string.IsNullOrEmpty(activity.ImageUrl) ? "/images/activityback2.png" : activity.ImageUrl;
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <div class="modern-activity-card mx-auto">
                                    <div class="row g-0 h-100">
                                        <div class="col-md-6">
                                            <div class="activity-image-modern">
                                                <div class="activity-bg-extended" style="background-image: url('@imageUrl')"></div>
                                                <img src="@imageUrl" alt="@activity.ActivityName" class="activity-img">
                                                <div class="activity-image-gradient"></div>
                                                <div class="elegant-image-overlay">
                                                    <div class="overlay-content">
                                                        <div class="overlay-text">查看詳情</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="activity-content-modern">
                                                <h3 class="activity-title-modern">@activity.ActivityName</h3>
                                                <p class="activity-description-modern">@activity.Description</p>
                                                <div class="activity-meta-info">
                                                    <div class="meta-item">
                                                        <span class="meta-label">地點</span>
                                                        <span class="meta-value">@activity.Location</span>
                                                    </div>
                                                    <div class="meta-item">
                                                        <span class="meta-label">日期</span>
                                                        <span class="meta-value">@activity.StartDate.ToString("yyyy / MM / dd")</span>
                                                    </div>
                                                </div>
                                                <div class="activity-progress-modern">
                                                    <div class="progress-header">
                                                        <span class="progress-label">報名進度</span>
                                                        <span class="progress-percentage">@(activity.MaxParticipants > 0 ? Math.Round((double)activity.CurrentParticipants / activity.MaxParticipants * 100, 0) : 0)%</span>
                                                    </div>
                                                    <div class="progress-bar-modern">
                                                        <div class="progress-fill" style="width: @(activity.MaxParticipants > 0 ? activity.CurrentParticipants * 100 / activity.MaxParticipants : 0)%"></div>
                                                    </div>
                                                </div>
                                                <div class="activity-actions-modern">
                                                    <a href="/Activity/Details/@activity.ActivityId" class="btn-modern primary">了解詳情</a>
                                                    <a href="/Auth/Login" class="btn-modern secondary">立即報名</a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#activityCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#activityCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                </div>
            </div>
        }
        else
        {
            <p class="no-activities-msg">目前沒有即將舉行的活動，請稍後再查看。</p>
        }
    </div>
</section>

<!-- CTA -->
<section class="cta-section">
    <div class="container">
        <h2 class="cta-heading">準備好了嗎？</h2>
        <p class="cta-body">每一個加入，都是改變的開始。無論您是要付出或需要支援，這裡都有您的位置。</p>
        <div class="cta-actions">
            <a href="/Auth/Register" class="btn-cta-primary">立即加入</a>
            <a href="/Home/Contact" class="btn-cta-outline">聯絡我們</a>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/homepage-new.js" asp-append-version="true"></script>
}

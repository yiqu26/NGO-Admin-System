@{
    ViewBag.Title = "聯絡我們";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/contact-page.css" asp-append-version="true" />
}

<!-- Hero -->
<div class="contact-hero">
    <div class="hero-inner">
        <p class="hero-eyebrow">恩舉基金會</p>
        <h1>聯絡我們</h1>
        <p class="hero-sub">有任何問題，歡迎隨時聯繫</p>
    </div>
</div>

<!-- 主體 -->
<div class="contact-body">

    <!-- 左側：聯絡資訊 -->
    <div class="contact-panel">
        <p class="panel-eyebrow">Reach Us</p>
        <h2 class="panel-heading">找到我們</h2>
        <hr class="contact-rule" />

        <dl class="contact-list">
            <dt>電話</dt>
            <dd>04-1234-5678</dd>

            <dt>傳真</dt>
            <dd>04-8765-4321</dd>

            <dt>地址</dt>
            <dd>
                408 台中市南屯區<br />
                公益路二段 51 號 18 樓
            </dd>

            <dt>服務時間</dt>
            <dd>
                週一至週五<br />
                09:00 — 17:00
            </dd>
        </dl>

        <a href="mailto:msit5566@gmail.com" class="contact-email-link">
            msit5566@gmail.com
        </a>
    </div>

    <!-- 右側：Google Maps -->
    <div class="contact-map-side">
        <iframe
            src="https://www.google.com/maps?q=台中市南屯區公益路二段51號&output=embed"
            allowfullscreen=""
            loading="lazy"
            title="恩舉基金會位置">
        </iframe>
    </div>

</div>

@section Scripts {
    <script>
        // Scroll 進場
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.classList.add('visible');
                    observer.unobserve(e.target);
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.contact-panel, .contact-map-side')
            .forEach(el => observer.observe(el));
    </script>
}

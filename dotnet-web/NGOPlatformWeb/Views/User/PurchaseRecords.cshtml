<!-- 使用者認購紀錄頁面 -->
@model NGOPlatformWeb.Models.ViewModels.Purchase.UserPurchaseRecordsViewModel
@{
    ViewData["Title"] = "我的認購紀錄";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile/profile-shared.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/purchase/purchase-records-standalone.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile/profile-dark-theme.css" asp-append-version="true" />
}

@{
    ViewBag.BodyClass = "profile-page";
}

<div class="purchase-records-page container py-5">

    <!-- 頁面標題 -->
    <div class="pr-header">
        <div class="pr-header__breadcrumb">
            <a asp-action="UserProfile" class="pr-breadcrumb-link">
                <i class="fas fa-user me-1"></i>個人資料
            </a>
            <i class="fas fa-chevron-right pr-breadcrumb-sep"></i>
            <span>援助紀錄</span>
        </div>
        <div class="pr-header__main">
            <div>
                <h1 class="pr-header__title">我的援助紀錄</h1>
                <p class="pr-header__subtitle">感謝您的愛心，每一份捐助都在創造奇蹟</p>
            </div>
            <a href="@Url.Action("Index", "Purchase")" class="pr-btn-primary">
                <i class="fas fa-plus"></i>提供援助
            </a>
        </div>
    </div>

    <!-- 統計卡片 -->
    <div class="pr-stats">
        <div class="pr-stat-card pr-stat-featured">
            <div class="pr-stat-icon">
                <i class="fas fa-medal"></i>
            </div>
            <div class="pr-stat-value">$@(Model.TotalDonated.ToString("N0"))</div>
            <div class="pr-stat-label">愛心捐助總額</div>
        </div>
        <div class="pr-stat-card">
            <div class="pr-stat-icon secondary">
                <i class="fas fa-heart-pulse"></i>
            </div>
            <div class="pr-stat-value">@(Model.TotalOrders)</div>
            <div class="pr-stat-label">援助次數</div>
        </div>
        <div class="pr-stat-card">
            <div class="pr-stat-icon sage">
                <i class="fas fa-gift"></i>
            </div>
            <div class="pr-stat-value">@(Model.Orders.Sum(o => o.TotalItems))</div>
            <div class="pr-stat-label">援助物資件數</div>
        </div>
        <div class="pr-stat-card">
            <div class="pr-stat-icon warm">
                <i class="fas fa-bolt"></i>
            </div>
            <div class="pr-stat-value">@(Model.Orders.Count(o => o.IsEmergencyOrder))</div>
            <div class="pr-stat-label">緊急響應</div>
        </div>
    </div>

    <!-- 篩選標籤 + 紀錄列表 -->
    <div class="pr-records-section">
        <div class="pr-records-header">
            <h3 class="pr-section-title">援助記錄 <span class="pr-count">共 @(Model.Orders.Count()) 筆</span></h3>
            <div class="pr-filter-tabs">
                <button class="pr-tab active" data-filter="all">
                    全部 <span class="pr-tab-count">@(Model.Orders.Count(o => o.IsEmergencyOrder || o.OrderSource == "package"))</span>
                </button>
                <button class="pr-tab" data-filter="unpaid">
                    未付款 <span class="pr-tab-count">@(Model.Orders.Count(o => (o.IsEmergencyOrder || o.OrderSource == "package") && (o.PaymentStatus == "待付款" || o.PaymentStatus == "付款失敗")))</span>
                </button>
                <button class="pr-tab" data-filter="emergency">
                    緊急援助 <span class="pr-tab-count">@(Model.Orders.Count(o => o.IsEmergencyOrder))</span>
                </button>
                <button class="pr-tab" data-filter="package">
                    組合包 <span class="pr-tab-count">@(Model.Orders.Count(o => o.OrderSource == "package"))</span>
                </button>
            </div>
        </div>

        @if (Model.Orders.Where(o => o.IsEmergencyOrder || o.OrderSource == "package").Any())
        {
            <div class="pr-order-list">
                @foreach (var order in Model.Orders.Where(o => o.IsEmergencyOrder || o.OrderSource == "package"))
                {
                    var statusClass = order.PaymentStatus switch {
                        "已付款" => "paid",
                        "待付款" => "pending",
                        "付款失敗" => "failed",
                        _ => "unknown"
                    };
                    var statusText = order.PaymentStatus switch {
                        "已付款" => "已付款",
                        "待付款" => "待付款",
                        "付款失敗" => "付款失敗",
                        _ => order.PaymentStatus ?? "未知"
                    };
                    var paymentMethod = order.PaymentMethod ?? "credit_card";
                    var paymentText = paymentMethod.ToLower() switch {
                        "atm" => "ATM轉帳",
                        "ecpay" => "綠界支付",
                        "line_pay" => "LINE Pay",
                        "apple_pay" => "Apple Pay",
                        "google_pay" => "Google Pay",
                        _ => "信用卡"
                    };
                    var paymentIcon = paymentMethod.ToLower() switch {
                        "atm" => "fas fa-university",
                        "ecpay" => "fas fa-mobile-alt",
                        "line_pay" => "fab fa-line",
                        "apple_pay" => "fab fa-apple-pay",
                        "google_pay" => "fab fa-google-pay",
                        _ => "fas fa-credit-card"
                    };
                    <div class="order-card @(order.IsEmergencyOrder ? "emergency-type" : "package-type")"
                         data-type="@(order.IsEmergencyOrder ? "emergency" : "package")"
                         data-payment-status="@order.PaymentStatus"
                         data-order-id="@order.OrderId">

                        <div class="order-header">
                            <div class="order-meta">
                                <span class="order-type-badge @(order.IsEmergencyOrder ? "emergency" : "package")">
                                    @(order.IsEmergencyOrder ? "🚨 緊急援助" : "📦 組合包")
                                </span>
                                <span class="order-date">@order.OrderDate.ToString("MM月dd日 HH:mm")</span>
                            </div>
                            <div class="order-right">
                                <span class="order-amount">$@(order.TotalPrice.ToString("N0"))</span>
                                <span class="order-status status-@statusClass">@statusText</span>
                                <span class="order-payment-method"><i class="@paymentIcon"></i> @paymentText</span>
                                <button class="toggle-btn" data-order-id="@order.OrderId" onclick="toggleDetails(@order.OrderId)">
                                    詳情 <i class="fas fa-chevron-down"></i>
                                </button>
                            </div>
                        </div>

                        <div class="order-details" id="details-@order.OrderId">
                            <div class="order-details-inner">
                                <div class="supplies-grid">
                                    @if (order.Items.Any())
                                    {
                                        @foreach (var item in order.Items)
                                        {
                                            <div class="supply-item">
                                                <div class="supply-image">
                                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/user-default.png" : item.ImageUrl)"
                                                         alt="@item.SupplyName" loading="lazy" />
                                                </div>
                                                <div class="supply-info">
                                                    <div class="supply-name">@item.SupplyName</div>
                                                    <div class="supply-qty">x @item.Quantity</div>
                                                </div>
                                                <div class="supply-price">$@item.TotalPrice.ToString("N0")</div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="supply-item">
                                            <div class="supply-info">
                                                <div class="supply-name">援助物資</div>
                                                <div class="supply-qty">x 1</div>
                                            </div>
                                            <div class="supply-price">$@order.TotalPrice.ToString("N0")</div>
                                        </div>
                                    }
                                </div>

                                <div class="order-actions">
                                    @if (order.PaymentStatus == "待付款")
                                    {
                                        <a href="@Url.Action("RetryPayment", "Purchase", new { orderId = order.OrderId })"
                                           class="order-action-btn primary">
                                            <i class="fas fa-credit-card"></i>重新付款
                                        </a>
                                    }
                                    else if (order.PaymentStatus == "付款失敗")
                                    {
                                        <a href="@Url.Action("RetryPayment", "Purchase", new { orderId = order.OrderId })"
                                           class="order-action-btn warning">
                                            <i class="fas fa-redo"></i>重試付款
                                        </a>
                                    }
                                    else if (order.PaymentStatus == "已付款")
                                    {
                                        <button class="order-action-btn secondary" onclick="window.print()">
                                            <i class="fas fa-download"></i>下載收據
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="pr-empty-state">
                <div class="pr-empty-icon">
                    <i class="fas fa-heart"></i>
                </div>
                <h4>還沒有認購紀錄</h4>
                <p>
                    您的愛心捐贈能為需要幫助的家庭帶來溫暖<br>
                    一起加入愛心行列，用善意點亮希望！
                </p>
                <a href="@Url.Action("Index", "Purchase")" class="pr-btn-primary">
                    <i class="fas fa-donate me-2"></i>開始認購
                </a>
            </div>
        }
    </div>

    <!-- 感謝區塊 -->
    @if (Model.Orders.Any())
    {
        <div class="pr-gratitude">
            <div class="row align-items-center g-4">
                <div class="col-md-7">
                    <i class="fas fa-hands-helping pr-gratitude-icon"></i>
                    <h3 class="pr-gratitude-title">感謝您的愛心</h3>
                    <p class="pr-gratitude-text">
                        您的每一份捐贈都經過我們的專業配送，確保送達最需要的個案手中。
                        您的善舉不僅提供了物質支援，更是傳遞了社會的溫暖與關懷。
                    </p>
                    <p class="pr-gratitude-contact">
                        如有任何問題，歡迎隨時
                        <a href="@Url.Action("Contact", "Home")">聯絡我們</a>
                    </p>
                </div>
                <div class="col-md-5">
                    <div class="pr-impact-stats">
                        <div class="pr-impact-item">
                            <div class="pr-impact-number">100%</div>
                            <div class="pr-impact-label">物資送達率</div>
                        </div>
                        <div class="pr-impact-item">
                            <div class="pr-impact-number">24h</div>
                            <div class="pr-impact-label">緊急援助回應</div>
                        </div>
                        <div class="pr-impact-item">
                            <div class="pr-impact-number">@(Model.Orders.Sum(o => o.TotalItems))+</div>
                            <div class="pr-impact-label">您的愛心物資</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // 篩選 tabs
        document.addEventListener('DOMContentLoaded', function () {
            const tabs = document.querySelectorAll('.pr-tab');
            const cards = document.querySelectorAll('.order-card');

            tabs.forEach(tab => {
                tab.addEventListener('click', function () {
                    tabs.forEach(t => t.classList.remove('active'));
                    this.classList.add('active');

                    const filter = this.dataset.filter;
                    cards.forEach(card => {
                        const type = card.dataset.type;
                        const status = card.dataset.paymentStatus;
                        let show = false;

                        if (filter === 'all') {
                            show = true;
                        } else if (filter === 'unpaid') {
                            show = status === '待付款' || status === '付款失敗';
                        } else if (filter === 'emergency') {
                            show = type === 'emergency';
                        } else if (filter === 'package') {
                            show = type === 'package';
                        }

                        card.style.display = show ? '' : 'none';
                    });
                });
            });
        });

        // 展開 / 收起詳情
        function toggleDetails(orderId) {
            const details = document.getElementById('details-' + orderId);
            const btn = document.querySelector('[data-order-id="' + orderId + '"].toggle-btn');
            if (!details) return;

            const isExpanded = details.classList.contains('expanded');
            details.classList.toggle('expanded');
            if (btn) btn.classList.toggle('open', !isExpanded);
        }
    </script>
}

{
  // 複製此檔案為 appsettings.json 並填入實際值
  // appsettings.json 已在 .gitignore，不會進版控

  "ConnectionStrings": {
    // 本機 SQL Server 範例：Server=HOSTNAME\\INSTANCE;Database=NGOPlatformDb;Trusted_Connection=True;TrustServerCertificate=True;
    "DefaultConnection": "Server=YOUR_SERVER\\INSTANCE;Database=NGOPlatformDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },

  "AllowedHosts": "*",

  // JWT 設定（React Admin 後台使用）
  "JwtSettings": {
    "SecretKey": "your-super-secret-jwt-key-at-least-32-characters-long",
    "Issuer": "NGOPlatformAPI",
    "Audience": "NGOPlatformClient",
    "ExpiryInMinutes": 60
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:5066"
    ]
  },

  // AI 功能設定
  // Provider 可設為 "OpenAI"（預設）或 "Azure"
  // 選 OpenAI：只需填 AI:OpenAI:ApiKey，三項 AI 功能（GPT / DALL-E / Whisper）全部啟用
  // 選 Azure：需填 AI:Azure:Endpoint 和 AI:Azure:ApiKey
  "AI": {
    "Provider": "OpenAI",
    "OpenAI": {
      "ApiKey": "sk-your-openai-api-key"
    },
    "Azure": {
      "Endpoint": "https://YOUR_RESOURCE.openai.azure.com/",
      "ApiKey": "your-azure-openai-api-key",
      "GptDeployment": "gpt-4.1",
      "DalleDeployment": "dall-e-3"
    },
    "AzureSpeech": {
      "SubscriptionKey": "your-azure-speech-key",
      "Region": "eastasia"
    }
  },

  // 檔案儲存設定
  // Provider 可設為 "Local"（預設）或 "Azure"
  // Local：檔案存到 api/uploads/，透過 /uploads 靜態路由存取
  "FileStorage": {
    "Provider": "Local",
    "Azure": {
      "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=...;",
      "ContainerName": "ngo"
    }
  }
}
